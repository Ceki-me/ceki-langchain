{
  "name": "@langchain/ceki",
  "version": "0.1.0",
  "description": "LangChain tool for Ceki — real Chrome sessions for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "lint": "eslint src",
    "prepublishOnly": "npm run build && npm run test"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "keywords": ["langchain", "tool", "browser", "ai-agent", "automation", "ceki", "chrome"],
  "author": "iWedmak",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ceki-me/ceki-langchain.git",
    "directory": "packages/ts"
  },
  "homepage": "https://ceki.me",
  "bugs": "https://github.com/Ceki-me/ceki-langchain/issues",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@langchain/core": "^0.3.0"
  },
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0"
  }
}
